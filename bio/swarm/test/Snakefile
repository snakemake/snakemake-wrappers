rule swarm:
    input:
        "{file}",
    output:
        structure="out/{file}.struct.tsv",
        network="out/{file}.network.tsv",
        output="out/{file}.clusters",
        statistics="stats/{file}.stats.tsv",
        uclust="out/{file}.uclust.tsv",
        seeds="out/{file}.seeds.fas",
        log="out/{file}.log",
    log:
        "logs/{file}.log",
    threads: 4
    params:
        extra="--fastidious --differences 1 --usearch-abundance",
    wrapper:
        "master/bio/swarm"
