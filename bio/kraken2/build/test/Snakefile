rule kraken2_build:
    input:
        db="{db}",  # Folder containing the library and taxonomy subfolders, to build the database
    output:
        hash="{db}/hash.k2d",
        opts="{db}/opts.k2d",
        taxo="{db}/taxo.k2d",
    log:
        "{db}/build.log",
    params:
        extra="",
    wrapper:
        "master/bio/kraken2/build"
