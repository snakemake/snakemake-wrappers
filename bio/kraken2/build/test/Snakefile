rule kraken2_build:
    input:
        db="{db}",  # Folder containing the library and taxonomy subfolders, to build the database
    output:
        multiext("{db}/",  # the {db} part here needs to exactly match the {db} part in `input:`
            hash="hash.k2d",  # this filename is required by kraken2
            opts="opts.k2d",  # this filename is required by kraken2
            taxo="taxo.k2d",  # this filename is required by kraken2
        ),
    log:
        "{db}/build.log",
    params:
        extra="",
    wrapper:
        "master/bio/kraken2/build"
