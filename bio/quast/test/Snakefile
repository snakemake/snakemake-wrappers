rule quast:
    input:
        fasta="genome.fasta",
        ref="genome.fasta",
        #gff="annotations.gff",
        #pe1="reads_R1.fastq",
        #pe2="reads_R2.fastq",
        #pe12="reads.fastq",
        #mp1="matereads_R1.fastq",
        #mp2="matereads_R2.fastq",
        #mp12="matereads.fastq",
        #single="single.fastq",
        #pacbio="pacbio.fas",
        #nanopore="nanopore.fastq",
        #ref_bam="ref.bam",
        #ref_sam="ref.sam",
        #bam=["s1.bam","s2.bam"],
        #sam=["s1.sam","s2.sam"],
        #sv_bedpe="sv.bed",
    output:
        report_html="a/report.html",
        report_tex="a/report.tex",
        report_txt="a/report.txt",
        report_pdf="a/report.pdf",
        report_tsv="a/report.tsv",
        treport_tex="a/treport.tex",
        treport_txt="a/treport.txt",
        treport_tsv="a/treport.tsv",
        stats_cum="a/stats/cumulative.pdf",
        stats_gc_plot="a/stats/gc.pdf",
        stats_gc_icarus="a/stats/gc.icarus.txt",
        stats_gc_fasta="a/stats/gc_fasta.pdf",
        stats_ngx="a/stats/NGx.pdf",
        stats_nx="a/stats/Nx.pdf",
        contigs="a/contigs.all_alignments.tsv",
        contigs_mis="a/contigs.mis_contigs.info",
        icarus="a/icarus.html",
        icarus_viewer="a/icarus_viewer.html",
    log:
        "logs/a.log",
    params:
        extra="--min-contig 5 --min-identity 95.0",
    wrapper:
        "master/bio/quast"


rule metaquast:
    input:
        fasta="genome.fasta",
        ref="genome.fasta",
        #gff="annotations.gff",
        #pe1="reads_R1.fastq",
        #pe2="reads_R2.fastq",
        #pe12="reads.fastq",
        #mp1="matereads_R1.fastq",
        #mp2="matereads_R2.fastq",
        #mp12="matereads.fastq",
        #single="single.fastq",
        #pacbio="pacbio.fas",
        #nanopore="nanopore.fastq",
        #ref_bam="ref.bam",
        #ref_sam="ref.sam",
        #bam=["s1.bam","s2.bam"],
        #sam=["s1.sam","s2.sam"],
        #sv_bedpe="sv.bed",
    output:
        report_html="b/report.html",
        report_tex="b/report.tex",
        report_txt="b/report.txt",
        report_pdf="b/report.pdf",
        report_tsv="b/report.tsv",
        treport_tex="b/treport.tex",
        treport_txt="b/treport.txt",
        treport_tsv="b/treport.tsv",
        stats_cum="b/stats/cumulative.pdf",
        stats_gc_plot="b/stats/gc.pdf",
        stats_gc_icarus="b/stats/gc.icarus.txt",
        stats_gc_fasta="b/stats/gc_fasta.pdf",
        stats_ngx="b/stats/NGx.pdf",
        stats_nx="b/stats/Nx.pdf",
        contigs="b/contigs.all_alignments.tsv",
        contigs_mis="b/contigs.mis_contigs.info",
        icarus="b/icarus.html",
        icarus_viewer="b/icarus_viewer.html",
    log:
        "logs/b.log",
    params:
        tool="metaquast",
        extra="--min-contig 5 --min-identity 95.0",
    wrapper:
        "master/bio/quast"
