rule test_grit_generate:
    output:
        directory("synthetic_beds"),
    threads: 7
    log:
        "test_grit_generate.log",
    params:
        command="generate",
        extra="",
    wrapper:
        "master/bio/grit_genomics"


rule test_grit_sort:
    input:
        bed="a.bed",
        # Optional path to genome file
        genome="genome.size",
    output:
        "sorted.bed",
    threads: 1
    log:
        "test_grit_sort.log",
    params:
        command="sort",
        extra="",
    wrapper:
        "master/bio/grit_genomics"


