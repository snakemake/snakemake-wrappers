rule test_grit_multiinter:
    input:
        # Any number of bed file(s)
        # No genome file expected for this subcommand
        bed=["a.bed", "b.bed"],
    output:
        "intersections.bed",
    threads: 1
    log:
        "test_grit_multiinter.log",
    params:
        command="multiinter",
        extra="",
    wrapper:
        "master/bio/grit_genomics"


