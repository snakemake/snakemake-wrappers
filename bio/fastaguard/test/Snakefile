rule fastaguard_pass:
    input:
        fasta="data/pass.fa",
    output:
        html="pass/fastaguard_report.html",
        json="pass/fastaguard.json",
        tsv="pass/fastaguard.tsv",
        multiqc="pass/fastaguard_mqc.json",
        exit_code="pass/fastaguard.exit_code",
    log:
        "logs/pass.fastaguard.log",
    params:
        profile="assembly",
        gate="pipeline",
        extra="",
    wrapper:
        "master/bio/fastaguard"


