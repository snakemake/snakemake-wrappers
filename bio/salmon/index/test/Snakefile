rule salmon_index:
    input:
        sequences="assembly/transcriptome.fasta",
    output:
        multiext(
            "salmon/transcriptome_index/",
            "index.ssi",
            "refseq_offsets.json",
            "index.ectab",
            "index.ctab",
            "refseq.bin",
            "index.ssi.mphf",
            "index.refinfo",
            "info.json",
            "duplicate_clusters.tsv",
        ),
    log:
        "logs/salmon/transcriptome_index.log",
    threads: 2
    params:
        # optional parameters
        extra="",
    wrapper:
        "master/bio/salmon/index"
