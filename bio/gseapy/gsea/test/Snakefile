rule test_gseapy_prerank:
    input:
        rank="genes.rnk",
        gmt="geneset.gmt",
    output:
        gmt="out/prerank/gene_sets.gmt",
        csv="out/prerank/results.csv",
        prerank=directory("out/prerank/results_dir"),
    log:
        wrapper="logs/prerank.wrapper.log",
        gseapy="logs/prerank.log",
    threads: 1
    params:
        extra={
            "min_size": 1,
        },
        # gene_sets = [""] # Optional list of gene sets available on biomart
    wrapper:
        "master/bio/gseapy/gsea"
