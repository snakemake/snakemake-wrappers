rule test_yq_concat:
    input:
        ["bazquux.yaml", "foobar.yaml"],
    output:
        "concat.yaml",
    log:
        "test_yq_concat.log",
    threads: 1
    params:
        extra="",
        subcommand="",
        expression="",
    wrapper:
        "master/utils/go-yq"


rule test_yq_simple_yaml_update:
    input:
        "foobar.yaml",
    output:
        "updated.yaml",
    log:
        "test_yq_simple_yaml_update.log",
    threads: 1
    params:
        extra="",
        subcommand="",
        expression='.[].foo = "foobar"',
    wrapper:
        "master/utils/go-yq"


rule test_yq_evaluate_yaml_content:
    input:
        "eval.yaml",
