        expression="eval(.pathExp)",
    wrapper:
        "master/utils/go-yq"


rule test_yq_split_yaml:
    input:
        "concat.yaml",
    output:
        "foo_bar.yml",
        "foo_bar2.yml",
    log:
        "test_yq_split_yaml.log",
    threads: 1
    params:
        extra="-s '\"foo_\" + .foo'",
        subcommand="",
        expression=".[]",
    wrapper:
        "master/utils/go-yq"


